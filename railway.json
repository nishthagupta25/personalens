{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r personalens/requirements.txt && python -m spacy download en_core_web_sm"
  },
  "deploy": {
    "startCommand": "cd personalens/backend && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}